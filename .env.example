# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/hvac_poc

# ── File storage ───────────────────────────────────────────────
STORAGE_PATH=../data/quotes

# ── Estimator defaults ─────────────────────────────────────────
ESTIMATOR_NAME=Your Name
ESTIMATOR_INITIALS=YN
COMPANY_LOGO_PATH=C:\path\to\logo.bmp

# ── Security ───────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_generated_secret

# ── Production HTTPS (Cloudflare Tunnel) ───────────────────────
# Uncomment and set once tunnel is live
# ALLOWED_ORIGINS=https://bid.yourdomain.com

# ── Microsoft Entra ID (SSO) ───────────────────────────────────
# From your App Registration in portal.azure.com
AZURE_CLIENT_ID=your-client-id-here
AZURE_TENANT_ID=your-tenant-id-here

# ── Email (Microsoft 365 SMTP) ─────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=bids@yourdomain.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_NAME=Your Company HVAC Estimating
